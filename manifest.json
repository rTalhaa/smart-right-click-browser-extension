{
  "manifest_version": 3,
  "name": "Smart Right-Click Browser Extension",
  "version": "0.1.0",
  "description": "Highlight text, right-click, then analyze the selection in a premium same-page overlay.",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://en.wikipedia.org/*",
    "https://*.wikipedia.org/*",
    "https://www.wikidata.org/*",
    "https://gnews.io/*",
    "https://newsapi.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Smart Right-Click",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
